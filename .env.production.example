NODE_ENV=production
PORT=3101

# PostgreSQL (change credentials!)
DATABASE_URL=postgresql://flowtask:CHANGE_ME@localhost:5432/flowtask_prod

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=60

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_chars_random_string_here
JWT_REFRESH_SECRET=CHANGE_ME_another_min_32_chars_random_string

JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
CORS_ORIGIN=http://YOUR_SERVER_IP:3200
